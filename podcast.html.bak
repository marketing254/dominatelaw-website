<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <!-- Primary SEO -->
  <title>Law Firm Marketing Podcast | The Law Firm Growth Show — Dominate Law</title>
  <meta name="description" content="The Law Firm Growth Show: weekly podcast episodes covering SEO, social media, reviews, events, and lead generation for law firm owners and managing partners. Listen free.">
  <meta name="keywords" content="law firm marketing podcast, legal marketing podcast, attorney marketing podcast, law firm SEO podcast, lawyer podcast, legal industry podcast, law firm growth podcast">
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large">
  <link rel="canonical" href="https://www.dominatelaw.com/podcast.html">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://www.dominatelaw.com/podcast.html">
  <meta property="og:title" content="Law Firm Marketing Podcast | The Law Firm Growth Show — Dominate Law">
  <meta property="og:description" content="The Law Firm Growth Show: weekly podcast episodes covering SEO, social media, reviews, events, and lead generation for law firm owners and managing partners. Listen free.">
  <meta property="og:image" content="https://www.dominatelaw.com/images/og-image.jpg">
  <meta property="og:site_name" content="Dominate Law">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@dominatelaw">
  <meta name="twitter:title" content="Law Firm Marketing Podcast | The Law Firm Growth Show — Dominate Law">
  <meta name="twitter:description" content="The Law Firm Growth Show: weekly podcast episodes covering SEO, social media, reviews, events, and lead generation for law firm owners and managing partners. Listen free.">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='4' fill='%231B2A4A'/><text x='50%' y='50%' dominant-baseline='central' text-anchor='middle' font-family='Georgia' font-weight='900' font-size='14' fill='%23C9A84C'>DL</text></svg>">

  <!-- Styles -->
  <style>
/* ── RESET ──────────────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:16px}
body{font-family:'Inter',system-ui,sans-serif;color:#1a0800;background:#fff;overflow-x:hidden;cursor:none}
@media(hover:none){body{cursor:auto}}
img{max-width:100%;display:block}a{text-decoration:none;color:inherit}ul{list-style:none}
button{border:none;background:none;cursor:none;font:inherit}
input,select,textarea{font:inherit}

/* ── TOKENS ─────────────────────────────────────────────── */
:root{
  --brown:#60270F;--brown2:#7A3515;--brown3:#3A0D00;
  --gold:#C49A0A;--gold2:#9E7C08;--gold3:#E8C44A;
  --cream:#FBF7F4;--cream2:#F0E8E0;--warm:#2A1200;
  --muted:#6b5040;--border:#e8ddd6;--max:1280px;
  --ease:cubic-bezier(.4,0,.2,1);
  /* legacy aliases used in page content */
  --amber-dark:var(--brown);--amber-mid:var(--brown2);--amber-light:var(--gold);
  --light-cream:var(--cream);--dark-brown:var(--brown3);
}

/* ── CURSOR ────────────────────────────────────────────── */
#cur-ico,#cur-ring{pointer-events:none;position:fixed;z-index:9999;top:0;left:0}
#cur-ico{width:24px;height:24px;color:#60270F;opacity:1}
#cur-ico svg{width:100%;height:100%}
#cur-ring{width:48px;height:48px;border:2px solid var(--gold);border-radius:50%;opacity:.3;transition:opacity .3s}
.cur-ripple{pointer-events:none;position:fixed;z-index:9998;width:48px;height:48px;border:1px solid var(--gold);border-radius:50%;top:0;left:0;opacity:0;animation:ripple 1s ease-out infinite}
@keyframes ripple{0%{transform:scale(1);opacity:.5}to{transform:scale(2.5);opacity:0}}

/* ── PROGRESS BAR ──────────────────────────────────────── */
#progress{position:fixed;top:0;left:0;height:3px;width:0%;background:linear-gradient(90deg,var(--gold),var(--gold3));z-index:10000;transition:width .1s ease}

/* ── LAYOUT ────────────────────────────────────────────── */
.container{max-width:var(--max);margin:0 auto;padding:0 20px}
.grid{display:grid;gap:24px}
.grid-2{grid-template-columns:repeat(2,1fr)}
.grid-3{grid-template-columns:repeat(3,1fr)}
@media(max-width:768px){.grid-2,.grid-3{grid-template-columns:1fr}}

/* ── NAVIGATION ────────────────────────────────────────── */
.nav{position:fixed;top:0;left:0;right:0;background:#fff;z-index:1000;border-bottom:1px solid var(--border);padding:12px 0}
.nav-inner{max-width:var(--max);margin:0 auto;padding:0 20px;display:flex;justify-content:space-between;align-items:center}
.nav-logo{display:flex;align-items:center;gap:12px;font-weight:600;color:var(--brown)}
.nav-logo img{height:40px;width:auto}
.nav-logo-fb{display:none}
.nav-logo-fb.show{display:flex;align-items:center;gap:12px}
.nav-mark{width:40px;height:40px;background:var(--brown);color:#fff;border-radius:4px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px}
.nav-brand{display:flex;flex-direction:column;line-height:1.2;font-size:13px}
.nav-brand strong{color:var(--brown);font-weight:600}
.nav-brand em{font-style:normal;color:var(--gold);font-size:11px}
.nav-links{display:flex;gap:0;list-style:none}
.nav-item{position:relative;display:flex}
.nav-item>a{display:flex;align-items:center;padding:8px 14px;color:var(--brown);font-size:14px;font-weight:500;position:relative;transition:color .2s}
.nav-item>a:hover{color:var(--gold)}
.nav-item>a.active{color:var(--gold);border-bottom:2px solid var(--gold);padding-bottom:6px}
.nav-drop-trigger{display:flex;align-items:center;gap:6px;padding:8px 14px;color:var(--brown);font-size:14px;font-weight:500;cursor:pointer;transition:color .2s}
.nav-drop-trigger:hover{color:var(--gold)}
.nav-chevron{width:10px;height:6px;transition:transform .2s}
.nav-item.open .nav-chevron{transform:rotate(180deg)}
.nav-drop{position:absolute;top:100%;left:0;background:#fff;border:1px solid var(--border);border-radius:8px;padding:12px 0;min-width:280px;opacity:0;pointer-events:none;transform:translateY(-10px);transition:all .2s;box-shadow:0 4px 12px rgba(0,0,0,.1)}
.nav-item.open .nav-drop{opacity:1;pointer-events:auto;transform:translateY(0)}
.nav-drop a{display:flex;align-items:center;gap:12px;padding:10px 16px;color:var(--brown);font-size:13px;transition:background .2s}
.nav-drop a:hover{background:var(--cream)}
.nav-drop-icon{width:32px;height:32px;display:flex;align-items:center;justify-content:center;background:var(--cream);border-radius:6px;flex-shrink:0}
.nav-drop-text{display:flex;flex-direction:column}
.nav-drop-text strong{color:var(--brown);font-weight:600;font-size:13px}
.nav-drop-text span{color:var(--muted);font-size:12px}
.nav-mega{position:absolute;top:100%;left:50%;transform:translateX(-50%);background:#fff;border:1px solid var(--border);border-radius:8px;padding:20px;opacity:0;pointer-events:none;transform:translateX(-50%) translateY(-10px);transition:all .2s;box-shadow:0 8px 24px rgba(0,0,0,.12);min-width:600px;z-index:1001}
.nav-item.open .nav-mega{opacity:1;pointer-events:auto;transform:translateX(-50%) translateY(0)}
.nav-mega-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.nav-mega-col{display:flex;flex-direction:column;gap:12px}
.nav-mega-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--muted)}
.nav-mega-featured{padding:12px;background:var(--cream);border-radius:6px;margin-bottom:4px}
.nav-mega-featured a{display:block;color:var(--brown);text-decoration:none}
.nav-mega-featured h4{font-size:13px;font-weight:600;margin-bottom:4px;line-height:1.3}
.nav-mega-featured p{font-size:12px;color:var(--muted);margin-bottom:8px;line-height:1.4}
.nm-cta{font-size:11px;font-weight:600;color:var(--gold);display:inline-block}
.nav-mega-col>a{display:flex;align-items:center;gap:8px;padding:6px 0;color:var(--brown);font-size:13px;transition:color .2s}
.nav-mega-col>a:hover{color:var(--gold)}
.nav-mega-dot{width:4px;height:4px;background:var(--gold);border-radius:50%;display:inline-block;flex-shrink:0}
.mob-toggle{display:none;flex-direction:column;gap:4px;cursor:pointer;background:none;padding:0}
.mob-toggle span{width:24px;height:2px;background:var(--brown);border-radius:1px;transition:all .3s}
.mob-toggle.open span:nth-child(1){transform:rotate(45deg) translateY(10px)}
.mob-toggle.open span:nth-child(2){opacity:0}
.mob-toggle.open span:nth-child(3){transform:rotate(-45deg) translateY(-10px)}
@media(max-width:768px){.nav{padding:10px 0}.nav-links{display:none;position:absolute;top:100%;left:0;right:0;flex-direction:column;background:#fff;border-bottom:1px solid var(--border);z-index:999}.nav-links.open{display:flex}.nav-item{width:100%;border-bottom:1px solid var(--border)}.nav-item>a{width:100%;padding:12px 20px;border-bottom:none}.nav-item>a.active{border-bottom:none;padding-bottom:12px}.nav-drop,.nav-mega{position:static;opacity:1;pointer-events:auto;transform:none;border:none;box-shadow:none;background:var(--cream);padding:8px 0;min-width:unset}.mob-toggle{display:flex}.nav-drop a,.nav-mega-col>a{padding-left:40px}}

/* ── HERO ──────────────────────────────────────────────── */
.hero{padding:100px 0 60px;margin-top:60px;text-align:center}
.hero h1{font-size:48px;font-weight:700;line-height:1.2;color:var(--brown);margin-bottom:16px}
.hero p{font-size:18px;color:var(--muted);line-height:1.6;margin-bottom:24px}
.hero .cta{display:inline-block;background:var(--brown);color:#fff;padding:12px 28px;border-radius:6px;font-weight:600;transition:background .2s}
.hero .cta:hover{background:var(--brown2)}
@media(max-width:768px){.hero{padding:80px 0 40px}.hero h1{font-size:32px}.hero p{font-size:16px}}

/* ── SECTIONS ──────────────────────────────────────────── */
.section{padding:60px 0}
.section h2{font-size:36px;font-weight:700;color:var(--brown);margin-bottom:32px;text-align:center}
.section p{font-size:16px;color:var(--muted);line-height:1.7;margin-bottom:16px}
@media(max-width:768px){.section{padding:40px 0}.section h2{font-size:28px;margin-bottom:24px}}

/* ── CARDS ────────────────────────────────────────────── */
.card{background:#fff;border:1px solid var(--border);border-radius:8px;padding:24px;transition:all .3s}
.card:hover{border-color:var(--gold);box-shadow:0 4px 16px rgba(196,154,10,.1)}
.card h3{font-size:18px;font-weight:600;color:var(--brown);margin-bottom:12px}
.card p{font-size:14px;color:var(--muted);line-height:1.6}

/* ── EVENT CARDS ────────────────────────────────────────– */
.event-card{background:linear-gradient(135deg,var(--cream) 0%,#fff 100%);border:1px solid var(--border);border-radius:8px;padding:20px;transition:all .3s;position:relative;overflow:hidden}
.event-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform .3s}
.event-card:hover::before{transform:scaleX(1)}
.event-date{display:inline-block;background:var(--gold);color:#fff;padding:4px 8px;border-radius:4px;font-size:11px;font-weight:700;margin-bottom:8px}
.event-title{font-size:16px;font-weight:700;color:var(--brown);margin-bottom:8px}
.event-desc{font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:12px}
.event-meta{display:flex;gap:12px;font-size:12px;color:var(--muted);margin-bottom:12px}
.event-meta span{display:flex;align-items:center;gap:4px}
.event-cta{display:inline-block;color:var(--gold);font-weight:600;font-size:13px;cursor:pointer;transition:color .2s}
.event-cta:hover{color:var(--brown)}

/* ── CTA SECTIONS ──────────────────────────────────────── */
.cta-section{background:linear-gradient(135deg,var(--brown) 0%,var(--brown2) 100%);color:#fff;padding:60px;border-radius:8px;text-align:center;margin:60px 0}
.cta-section h2{color:#fff;margin-bottom:16px}
.cta-section p{color:rgba(255,255,255,.9);margin-bottom:24px}
.cta-section .cta{background:#fff;color:var(--brown);padding:12px 32px;border-radius:6px;font-weight:600;display:inline-block;transition:all .2s}
.cta-section .cta:hover{background:var(--cream);transform:translateY(-2px)}
@media(max-width:768px){.cta-section{padding:40px 20px}.cta-section h2{font-size:28px}}

/* ── REVIEWS ────────────────────────────────────────────– */
.review{background:#fff;border:1px solid var(--border);border-radius:8px;padding:24px;position:relative}
.review-stars{display:flex;gap:4px;margin-bottom:12px;font-size:16px}
.review-text{font-size:14px;color:var(--muted);line-height:1.7;margin-bottom:16px;font-style:italic}
.review-author{display:flex;align-items:center;gap:12px}
.review-avatar{width:40px;height:40px;background:var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:16px}
.review-info{display:flex;flex-direction:column}
.review-info strong{font-size:13px;color:var(--brown);font-weight:600}
.review-info span{font-size:12px;color:var(--muted)}

/* ── PODCAST ────────────────────────────────────────────– */
.episode{background:#fff;border:1px solid var(--border);border-radius:8px;padding:16px;display:flex;gap:16px;transition:all .3s}
.episode:hover{border-color:var(--gold);box-shadow:0 4px 12px rgba(0,0,0,.08)}
.episode-thumb{width:80px;height:80px;background:linear-gradient(135deg,var(--gold),var(--gold3));border-radius:6px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:32px;flex-shrink:0}
.episode-content{flex:1;display:flex;flex-direction:column}
.episode-label{font-size:11px;color:var(--gold);font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}
.episode-title{font-size:15px;font-weight:700;color:var(--brown);margin-bottom:6px}
.episode-desc{font-size:13px;color:var(--muted);line-height:1.5;margin-bottom:10px}
.episode-cta{color:var(--gold);font-weight:600;font-size:12px;cursor:pointer;transition:color .2s}
.episode-cta:hover{color:var(--brown)}

/* ── RESOURCES ────────────────────────────────────────── */
.resource{background:#fff;border:1px solid var(--border);border-radius:8px;padding:20px;text-align:center;transition:all .3s}
.resource:hover{border-color:var(--gold);box-shadow:0 4px 16px rgba(196,154,10,.1)}
.resource-icon{width:48px;height:48px;background:linear-gradient(135deg,var(--gold),var(--gold3));border-radius:6px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:24px;margin:0 auto 12px}
.resource-title{font-size:15px;font-weight:700;color:var(--brown);margin-bottom:8px}
.resource-desc{font-size:13px;color:var(--muted);line-height:1.5;margin-bottom:12px}
.resource-btn{display:inline-block;background:var(--gold);color:#fff;padding:8px 16px;border-radius:4px;font-size:12px;font-weight:600;transition:background .2s}
.resource-btn:hover{background:var(--gold2)}

/* ── BLOG ──────────────────────────────────────────────– */
.blog-card{background:#fff;border:1px solid var(--border);border-radius:8px;overflow:hidden;transition:all .3s}
.blog-card:hover{border-color:var(--gold);box-shadow:0 4px 16px rgba(0,0,0,.1);transform:translateY(-4px)}
.blog-card-img{width:100%;height:180px;background:linear-gradient(135deg,var(--gold),var(--gold3));display:flex;align-items:center;justify-content:center;font-size:48px;overflow:hidden}
.blog-card-img img{width:100%;height:100%;object-fit:cover}
.blog-card-content{padding:20px}
.blog-card-label{font-size:11px;color:var(--gold);font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px}
.blog-card-title{font-size:16px;font-weight:700;color:var(--brown);margin-bottom:8px;line-height:1.4}
.blog-card-desc{font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:12px}
.blog-card-meta{display:flex;justify-content:space-between;font-size:12px;color:var(--muted)}

/* ── ACCORDION ────────────────────────────────────────– */
.accordion-item{border-bottom:1px solid var(--border)}
.accordion-item:last-child{border-bottom:none}
.accordion-header{padding:20px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;background:#fff;transition:background .2s;user-select:none}
.accordion-header:hover{background:var(--cream)}
.accordion-header h3{font-size:15px;font-weight:600;color:var(--brown);margin:0}
.accordion-icon{width:20px;height:20px;display:flex;align-items:center;justify-content:center;color:var(--gold);transition:transform .3s}
.accordion-item.open .accordion-icon{transform:rotate(180deg)}
.accordion-content{max-height:0;overflow:hidden;background:var(--cream);transition:max-height .3s;padding:0 20px}
.accordion-item.open .accordion-content{max-height:1000px;padding:0 20px 20px}
.accordion-text{font-size:14px;color:var(--muted);line-height:1.7}

/* ── STATS ────────────────────────────────────────────── */
.stats-strip{background:linear-gradient(90deg,var(--brown),var(--brown2));color:#fff;padding:40px 0;text-align:center}
.stats-grid{max-width:var(--max);margin:0 auto;padding:0 20px;display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.stat-item{display:flex;flex-direction:column}
.stat-num{font-size:32px;font-weight:700;margin-bottom:4px}
.stat-label{font-size:13px;opacity:.9;line-height:1.4}
@media(max-width:768px){.stats-grid{grid-template-columns:repeat(2,1fr)}.stat-num{font-size:24px}}

/* ── FOOTER ────────────────────────────────────────────── */
footer{background:var(--brown);color:#fff;padding:40px 0;margin-top:60px}
footer .container{max-width:var(--max);margin:0 auto;padding:0 20px}
.footer-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:30px;margin-bottom:30px}
.footer-col h4{font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px}
.footer-col a{display:block;font-size:13px;color:rgba(255,255,255,.8);margin-bottom:8px;transition:color .2s}
.footer-col a:hover{color:#fff}
.footer-bottom{border-top:1px solid rgba(255,255,255,.1);padding-top:20px;text-align:center;font-size:12px;color:rgba(255,255,255,.7)}
@media(max-width:768px){.footer-grid{grid-template-columns:repeat(2,1fr);gap:20px}.footer-col h4{font-size:12px}}

/* ── MOBILE MENU ────────────────────────────────────────– */
.mob-acc-trigger{width:100%;padding:12px 20px;text-align:left;font-size:13px;font-weight:600;color:var(--brown);background:none;border:none;cursor:pointer;border-bottom:1px solid var(--border);transition:background .2s;display:flex;justify-content:space-between;align-items:center}
.mob-acc-trigger:hover{background:var(--cream)}
.mob-acc-trigger::after{content:'';width:12px;height:12px;border-right:2px solid var(--brown);border-bottom:2px solid var(--brown);transform:rotate(-45deg);transition:transform .3s}
.mob-acc-trigger.open::after{transform:rotate(135deg)}
.mob-acc-panel{max-height:0;overflow:hidden;background:var(--cream);transition:max-height .3s}
.mob-acc-panel.open{max-height:300px}
.mob-acc-item{padding:12px 20px 12px 40px;font-size:12px;color:var(--muted);border-bottom:1px solid var(--border)}
.mob-acc-item a{color:var(--brown);font-weight:500;transition:color .2s}
.mob-acc-item a:hover{color:var(--gold)}

/* ── RESPONSIVE ────────────────────────────────────────– */
@media(max-width:1024px){.grid-3{grid-template-columns:repeat(2,1fr)}.nav-mega{min-width:500px}.nav-mega-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:768px){
  .container{padding:0 16px}
  .hero h1{font-size:28px}
  .section h2{font-size:24px}
  .grid-2,.grid-3{grid-template-columns:1fr}
  .nav-mega{display:none!important}
}
  </style>

  <!-- Schema.org -->
  <script type="application/ld+json">{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Dominate Law",
  "url": "https://www.dominatelaw.com",
  "logo": "https://www.dominatelaw.com/images/logo.png",
  "description": "The #1 growth platform for law firm owners and managing partners.",
  "sameAs": [
    "https://www.linkedin.com/company/dominatelaw",
    "https://www.facebook.com/dominatelaw",
    "https://www.instagram.com/dominatelawofficial"
  ],
  "parentOrganization": {
    "@type": "Organization",
    "name": "Ekwa Marketing",
    "url": "https://www.ekwa.com"
  }
}</script>
</head>
<body>
  <!-- Cursor elements -->
  <div id="cur-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
  <div id="cur-ring"></div>
  <div class="cur-ripple"></div>

<!-- ═══ NAV ══════════════════════════════════════════════════════ -->
<nav class="nav" id="nav">
  <div class="nav-inner">
    <a href="index.html" class="nav-logo">
      <img src="https://www.dominatelaw.com/wp-content/themes/growingdentist/images/logo.png" alt="Dominate Law" onerror="this.style.display='none';document.getElementById('nav-fb').classList.add('show')">
      <div class="nav-logo-fb" id="nav-fb"><div class="nav-mark">DL</div><div class="nav-brand"><strong>Dominate Law</strong><em>by Ekwa</em></div></div>
    </a>
    <div class="nav-links" id="navLinks">
      <div class="nav-item"><a href="events.html" id="nl-events">Events</a></div>
