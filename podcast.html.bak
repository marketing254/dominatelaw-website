    <div style="border-top:1px solid rgba(255,255,255,.07);padding:20px 0;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;font-size:.74rem;color:rgba(255,255,255,.3)">
      <span>© 2026 Dominate Law by Ekwa Marketing. All rights reserved.</span>
      <div style="display:flex;gap:20px">
        <a href="#" style="color:rgba(255,255,255,.22);transition:color .2s" onmouseover="this.style.color='rgba(255,255,255,.5)'" onmouseout="this.style.color='rgba(255,255,255,.22)'">Privacy Policy</a>
        <a href="#" style="color:rgba(255,255,255,.22);transition:color .2s" onmouseover="this.style.color='rgba(255,255,255,.5)'" onmouseout="this.style.color='rgba(255,255,255,.22)'">Terms of Use</a>
        <a href="contact.html" style="color:rgba(255,255,255,.22);transition:color .2s" onmouseover="this.style.color='rgba(255,255,255,.5)'" onmouseout="this.style.color='rgba(255,255,255,.22)'">Contact</a>
      </div>
    </div>
  </div>
</footer>
<script>
/* Desktop dropdowns */
document.querySelectorAll('.nav-item').forEach(item => {
  const trigger = item.querySelector('.nav-drop-trigger');
  if (!trigger) return;
  let timer;
  item.addEventListener('mouseenter', () => { clearTimeout(timer); item.classList.add('open'); });
  item.addEventListener('mouseleave', () => { timer = setTimeout(() => item.classList.remove('open'), 120); });
  trigger.addEventListener('click', () => item.classList.contains('open') ? item.classList.remove('open') : item.classList.add('open'));
  document.addEventListener('click', e => { if (!item.contains(e.target)) item.classList.remove('open'); });
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') document.querySelectorAll('.nav-item.open').forEach(i => i.classList.remove('open')); });

/* Mobile menu */
const burger = document.getElementById('burger');
const mobMenu = document.getElementById('mob-menu');
const mobOvl  = document.getElementById('mob-overlay');
const mobCls  = document.getElementById('mob-close');
const openMenu = open => {
  mobMenu.classList.toggle('open', open);
  mobOvl.classList.toggle('open', open);
  burger.classList.toggle('open', open);
  document.body.style.overflow = open ? 'hidden' : '';
};
burger?.addEventListener('click', () => openMenu(!mobMenu.classList.contains('open')));
mobCls?.addEventListener('click', () => openMenu(false));
mobOvl?.addEventListener('click', () => openMenu(false));

/* Mobile accordion */
document.querySelectorAll('.mob-acc-trigger').forEach(btn => {
  btn.addEventListener('click', () => {
    const panelId = btn.id.replace('-trig', '-panel');
    const panel = document.getElementById(panelId);
    if (!panel) return;
    const isOpen = panel.classList.contains('open');
    document.querySelectorAll('.mob-acc-panel.open').forEach(p => p.classList.remove('open'));
    document.querySelectorAll('.mob-acc-trigger.open').forEach(t => t.classList.remove('open'));
    if (!isOpen) { panel.classList.add('open'); btn.classList.add('open'); }
  });
});

/* Cursor */
const cur = { x: 0, y: 0, size: 24 };
const ring = { x: 0, y: 0, size: 48, vx: 0, vy: 0 };
const ico = document.getElementById('cur-ico');
const ringEl = document.getElementById('cur-ring');

document.addEventListener('mousemove', (e) => {
  cur.x = e.clientX;
  cur.y = e.clientY;
  ico.style.left = (cur.x - cur.size / 2) + 'px';
  ico.style.top = (cur.y - cur.size / 2) + 'px';
  ring.vx += (cur.x - ring.x) * 0.15;
  ring.vy += (cur.y - ring.y) * 0.15;
  ring.x += ring.vx;
  ring.y += ring.vy;
  ring.vx *= 0.9;
  ring.vy *= 0.9;
  ringEl.style.left = (ring.x - ring.size / 2) + 'px';
  ringEl.style.top = (ring.y - ring.size / 2) + 'px';
});

/* Scroll Progress */
const progressBar = document.getElementById('progress');
if (progressBar) {
  window.addEventListener('scroll', () => {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const scrolled = (scrollTop / docHeight) * 100;
    progressBar.style.width = scrolled + '%';
  });
}
</script>
</body>
</html>