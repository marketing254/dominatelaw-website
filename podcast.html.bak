<section class="section" aria-labelledby="guest-heading">
  <div class="container" style="max-width:680px;">
    <div class="section-intro">
      <span class="label">Be a Guest</span>
      <h2 id="guest-heading">Are You a Legal Industry Expert?</h2>
      <p>We're always looking for attorneys, consultants, and legal marketing experts with valuable insights to share with our audience. Apply to be a guest below.</p>
    </div>
    <form data-form="contact" style="background:var(--light-bg);border:1px solid var(--border);border-radius:12px;padding:32px;">
      <div class="grid-2" style="gap:16px;">
        <div class="form-group"><label for="g-name">Your Name</label><input id="g-name" class="form-control" type="text" placeholder="First Last" required></div>
        <div class="form-group"><label for="g-email">Email Address</label><input id="g-email" class="form-control" type="email" placeholder="you@lawfirm.com" required></div>
      </div>
      <div class="form-group"><label for="g-expertise">Area of Expertise</label><input id="g-expertise" class="form-control" type="text" placeholder="e.g., Family Law SEO, Legal Technology, Podcast Marketing" required></div>
      <div class="form-group"><label for="g-topic">Proposed Topic</label><textarea id="g-topic" class="form-control" placeholder="What would you like to discuss on the show?"></textarea></div>
      <button type="submit" class="btn btn-primary btn-full">Submit Guest Application →</button>
    </form>
  </div>
</section>

