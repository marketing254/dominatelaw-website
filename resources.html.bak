  }
}</script>
</head>
<body>
  <!-- Cursor elements -->
  <div id="cur-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
  <div id="cur-ring"></div>
  <div class="cur-ripple"></div>

<!-- ═══ NAV ══════════════════════════════════════════════════════ -->
<nav class="nav" id="nav">
  <div class="nav-inner">
    <a href="index.html" class="nav-logo">
      <img src="https://www.dominatelaw.com/wp-content/themes/growingdentist/images/logo.png" alt="Dominate Law" onerror="this.style.display='none';document.getElementById('nav-fb').classList.add('show')">
      <div class="nav-logo-fb" id="nav-fb"><div class="nav-mark">DL</div><div class="nav-brand"><strong>Dominate Law</strong><em>by Ekwa</em></div></div>
    </a>
    <div class="nav-links" id="navLinks">
      <div class="nav-item"><a href="events.html" id="nl-events">Events</a></div>
